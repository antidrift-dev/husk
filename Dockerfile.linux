FROM node:22-bookworm AS build

# Install native build deps for node-pty + electron-builder packaging tools
RUN apt-get update && apt-get install -y \
    build-essential python3 libfuse2 rpm fakeroot dpkg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies first (cache layer)
COPY package.json package-lock.json ./
RUN npm ci

# Copy source
COPY . .

# Build and package for Linux
RUN npm run build && npx electron-builder --linux AppImage deb

# Output is in /app/release/
