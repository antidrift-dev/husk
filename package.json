{
  "name": "husk",
  "version": "0.2.87",
  "author": {
    "name": "Reloop Labs, LLC",
    "email": "hello@antidrift.dev"
  },
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "tsx scripts/bump-build.ts && npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "test:perf": "vitest run src/main/sessions-perf.test.ts",
    "bench": "vitest bench",
    "bench:run": "tsx scripts/run-bench.ts",
    "bench:history": "tsx scripts/build-bench-history.ts",
    "test:e2e": "npm run build && npx playwright test",
    "test:e2e:launch": "HUSK_TEST=1 npx playwright test e2e/app-launch.spec.ts",
    "test:e2e:sessions": "HUSK_TEST=1 npx playwright test e2e/sessions.spec.ts",
    "test:e2e:splits": "HUSK_TEST=1 npx playwright test e2e/splits.spec.ts",
    "test:e2e:settings": "HUSK_TEST=1 npx playwright test e2e/settings.spec.ts",
    "test:e2e:sidebar": "HUSK_TEST=1 npx playwright test e2e/sidebar.spec.ts",
    "test:e2e:themes": "HUSK_TEST=1 npx playwright test e2e/themes.spec.ts",
    "test:e2e:tabs": "HUSK_TEST=1 npx playwright test e2e/tab-position.spec.ts",
    "test:e2e:bugs": "HUSK_TEST=1 npx playwright test e2e/bug-fixes.spec.ts",
    "test:e2e:perf": "HUSK_TEST=1 npx playwright test e2e/performance.spec.ts",
    "test:e2e:perfmon": "HUSK_TEST=1 npx playwright test e2e/perf-monitor.spec.ts",
    "test:e2e:profiles": "HUSK_TEST=1 npx playwright test e2e/profiles.spec.ts",
    "test:e2e:features": "HUSK_TEST=1 npx playwright test e2e/features.spec.ts",
    "test:e2e:multiwin": "HUSK_TEST=1 npx playwright test e2e/multi-window.spec.ts",
    "test:e2e:persist": "HUSK_TEST=1 npx playwright test e2e/persistence.spec.ts",
    "test:e2e:keyboard": "HUSK_TEST=1 npx playwright test e2e/keyboard.spec.ts",
    "test:e2e:chaos": "HUSK_TEST=1 npx playwright test e2e/chaos-monkey.spec.ts",
    "test:e2e:onboarding": "HUSK_TEST=1 npx playwright test e2e/onboarding.spec.ts",
    "test:e2e:quake": "HUSK_TEST=1 npx playwright test e2e/quake-mode.spec.ts",
    "test:e2e:notifications": "HUSK_TEST=1 npx playwright test e2e/notifications.spec.ts",
    "test:e2e:about": "HUSK_TEST=1 npx playwright test e2e/about.spec.ts",
    "test:e2e:bounds": "HUSK_TEST=1 npx playwright test e2e/window-bounds.spec.ts",
    "test:e2e:isolation": "HUSK_TEST=1 npx playwright test e2e/session-isolation.spec.ts",
    "test:all": "npm run test && npm run test:e2e",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "dev.antidrift.husk",
    "productName": "Husk",
    "buildVersion": "87",
    "artifactName": "${productName}-${version}-b${buildVersion}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "themes/**/*",
      "build-number.json",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "themes",
        "to": "themes"
      },
      {
        "from": "src/renderer/fonts",
        "to": "fonts"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": "Reloop Labs, LLC (MV45NBJTQP)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "node-pty": "^1.0.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^35",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1",
    "react": "^19",
    "react-dom": "^19",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3"
  }
}
